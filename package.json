{
	"name": "@yiitap/root",
	"description": "Yiitap is a WYSIWYG rich-text block-based editor built on top of tiptap.",
	"author": {
		"name": "Yiitap",
		"email": "pileaxai@gmail.com"
	},
	"license": "MIT",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*",
		"packages/extensions/*",
		"packages/utils/*"
	],
	"scripts": {
		"dev": "pnpm -F 'app-vue' dev",
		"dev-react": "pnpm -F 'app-react' dev",
		"i18n-generate": "pnpm -F '@yiitap/i18n' generate",
		"i18n-generate-zh": "pnpm -F '@yiitap/i18n' generate-zh",
		"icon": "pnpm -F '@yiitap/icon' build",
		"test": "pnpm --if-present -r run test",
		"test-ci": "pnpm --if-present -r run test-ci",
		"test-libs": "pnpm -F '@yiitap/*' run test",
		"test-vue": "pnpm -F '@yiitap/vue' run test",
		"lint": "pnpm eslint '**/*.{vue,ts,js}'",
		"lint-fix": "pnpm eslint '**/*.{vue,ts,js}' --fix",
		"build": "pnpm build-packages && pnpm build-app-vue",
		"build-packages": "pnpm -r -F '@stan-custom-yiitap/*' run build",
		"build-app-vue": "pnpm -F '@stan-custom-yiitap/app-vue' run build",
		"publish": "pnpm build && pnpm changeset publish",
		"pre-push": "pnpm lint-fix && pnpm test-ci && pnpm build",
		"preview": "pnpm -F 'app-vue' preview"
	},
	"packageManager": "pnpm@10.6.2",
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/js": "^9.21.0",
		"@tsconfig/node20": "^20.1.2",
		"@types/node": "20.8.10",
		"@vitejs/plugin-vue": "^5.2.1",
		"@vue/compiler-dom": "^3.3.8",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/test-utils": "^2.4.1",
		"@vue/tsconfig": "^0.4.0",
		"eslint": "^10.0.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.8.0",
		"jsdom": "^22.1.0",
		"lint-staged": "^15.0.2",
		"prettier": "^3.0.3",
		"typescript": "^5.2.2",
		"vite": "^6.2.0",
		"vitest": "^3.0.8"
	},
	"engines": {
		"node": ">=20.9.0",
		"pnpm": ">8.0.0"
	},
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"@algolia/client-search"
			]
		},
		"overrides": {
			"layout-base": "2.0.1",
			"prosemirror-model": "1.25.4",
			"prosemirror-state": "1.4.4",
			"prosemirror-view": "1.41.6"
		},
		"patchedDependencies": {
			"@changesets/assemble-release-plan@6.0.9": "patches/@changesets__assemble-release-plan@6.0.9.patch"
		}
	}
}
